{
  "name": "trusttrace-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "TrustTrace React Native app (Expo bare workflow, iOS 16+/Android 10+) -- see spec Target Environment. NOT installable/runnable in this sandbox (no npm registry access); dependency versions below reflect the spec's named stack.",
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest --config jest.config.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prebuild": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "build:android": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@shopify/react-native-skia": "^1.2.0",
    "@types/react": "~18.2.79",
    "expo": "~51.0.0",
    "expo-build-properties": "~0.12.5",
    "expo-constants": "~16.0.0",
    "expo-file-system": "~17.0.1",
    "llama.rn": "^0.4.8",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "~3.31.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "react-test-renderer": "18.2.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.4.0"
  }
}
